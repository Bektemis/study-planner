# Copy this file to .env and fill in your values
# Never commit .env to git!

# Database — get a free PostgreSQL URL from https://railway.app or https://supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/study_planner"

# JWT secret — make this a long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="replace_this_with_a_long_random_secret"

# Port the server runs on locally
PORT=3000

# Frontend URL (for CORS) — in development this is your Live Server URL
CLIENT_URL="http://127.0.0.1:5500"
